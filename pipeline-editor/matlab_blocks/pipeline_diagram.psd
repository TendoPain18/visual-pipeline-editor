    {
      "id": 1002,
      "name": "FileSink",
      "fileName": "file_sink.m",
      "code": "function file_sink(pipeIn)\n% FILE_SINK  Streaming file sink — manual I/O version.\n\n    block_config = struct( ...\n        'name',             'FileSink', ...\n        'inputs',           1, ...\n        'outputs',          0, ...\n        'inputPacketSizes', 1501, ...\n        'inputBatchSizes',  44740, ...\n        'LTR',              false, ...\n        'startWithAll',     true, ...\n        'socketHost',       'localhost', ...\n        'socketPort',       9001, ...\n        'outputDirectory',  'C:\\Users\\amrga\\Downloads\\final\\pipeline-editor\\Output_Files', ...\n        'description',      'Streaming file sink with error tracking and on-completion error report' ...\n    );\n\n    run_generic_block({pipeIn}, {}, block_config, @process_fn, @init_fn);\nend\n\n%% ─── Init ───────────────────────────────────────────────────────────────────\nfunction state = init_fn(config)\n    START_FLAG      = uint8([0xAA, 0x55, 0xAA, 0x55]);\n    END_FLAG        = uint8([0x55, 0xAA, 0x55, 0xAA]);\n    FILENAME_LENGTH = 256;\n    REPETITIONS     = 10;\n\n    outDir = config.outputDirectory;\n    if ~exist(outDir, 'dir'); mkdir(outDir); end\n\n    reportPath = fullfile(outDir, 'error_report.txt');\n    fid = fopen(reportPath, 'w');\n    if fid ~= -1\n        fprintf(fid, '========================================\\n');\n        fprintf(fid, 'FILE TRANSMISSION ERROR REPORT\\n');\n        fprintf(fid, '========================================\\n');\n        fprintf(fid, 'Started: %s\\nMode: STREAMING\\n\\nFILES RECEIVED:\\n', datestr(now));\n        fprintf(fid, '========================================\\n\\n');\n        fclose(fid);\n    end\n\n    fprintf('[FileSink] Output directory: %s\\n', outDir);\n    fprintf('[FileSink] Error report:     %s\\n', reportPath);\n\n    state = struct( ...\n        'streamBuffer',      uint8([]), ...\n        'currentFile',       struct('active',false,'fid',-1), ...\n        'filesReceived',     0, ...\n        'totalErrorCount',   uint64(0), ...\n        'outputDirectory',   outDir, ...\n        'reportPath',        reportPath, ...\n        'START_FLAG',        START_FLAG, ...\n        'END_FLAG',          END_FLAG, ...\n        'FILENAME_LENGTH',   FILENAME_LENGTH, ...\n        'REPETITIONS',       REPETITIONS, ...\n        'lastProgressPct',   -1 ...\n    );\nend\n\n%% ─── Process ────────────────────────────────────────────────────────────────\nfunction process_fn(pipeIn, ~, state, config)\n    inp = pipeIn{1};\n\n    PACKET_SIZE = inp.getPacketSize();   % 1501\n    DATA_SIZE   = PACKET_SIZE - 1;       % 1500 (last byte = error flag)\n\n    % ── Read a batch ──────────────────────────────────────────────────────────\n    [inputBatch, actualCount] = inp.read();\n\n    % ── EOF signal ────────────────────────────────────────────────────────────\n    if actualCount == 0\n        if state.currentFile.active && state.currentFile.fid ~= -1\n            fclose(state.currentFile.fid);\n            if exist(state.currentFile.tempPath,'file')\n                movefile(state.currentFile.tempPath, state.currentFile.finalPath);\n            end\n            appendReport(state.reportPath, state.currentFile);\n            state.filesReceived = state.filesReceived + 1;\n            state.currentFile.active = false;\n        end\n\n        fid = fopen(state.reportPath, 'a');\n        if fid ~= -1\n            fprintf(fid, '========================================\\nSUMMARY\\n');\n            fprintf(fid, 'Finished:     %s\\n', datestr(now));\n            fprintf(fid, 'Total files:  %d\\nTotal errors: %d\\n', ...\n                state.filesReceived, state.totalErrorCount);\n            fprintf(fid, '========================================\\n');\n            fclose(fid);\n        end\n        fprintf('\\n[FileSink] ALL FILES RECEIVED — %d files, %d errors\\n', ...\n            state.filesReceived, state.totalErrorCount);\n        error('MATLAB:MEX:ErrMsgTxt', 'Block finished');\n    end\n\n    % ── Unpack batch ──────────────────────────────────────────────────────────\n    batchMatrix  = reshape(inputBatch(1:actualCount*PACKET_SIZE), PACKET_SIZE, actualCount);\n    dataMatrix   = batchMatrix(1:DATA_SIZE, :);\n    errorFlags   = batchMatrix(PACKET_SIZE, :);\n\n    newData = uint8(int32(dataMatrix(:)) + 128);\n\n    state.totalErrorCount = state.totalErrorCount + uint64(sum(errorFlags ~= 0));\n    if state.currentFile.active\n        state.currentFile.errorCount = state.currentFile.errorCount + ...\n            uint64(sum(errorFlags ~= 0));\n    end\n\n    state.streamBuffer = [state.streamBuffer; newData];\n\n    % ── Parse stream ──────────────────────────────────────────────────────────\n    while true\n        if ~state.currentFile.active\n            startPos = findPattern(state.streamBuffer, state.START_FLAG);\n            if isempty(startPos)\n                if numel(state.streamBuffer) > 4096\n                    state.streamBuffer = state.streamBuffer(end-4095:end);\n                end\n                break;\n            end\n\n            metaSize = 4 + state.FILENAME_LENGTH*state.REPETITIONS + 8*state.REPETITIONS;\n            if numel(state.streamBuffer) < startPos + metaSize - 1; break; end\n\n            % Extract filename (majority vote)\n            nameStart = startPos + 4;\n            names = cell(state.REPETITIONS,1);\n            for r = 1:state.REPETITIONS\n                nb = state.streamBuffer(nameStart+(r-1)*state.FILENAME_LENGTH : ...\n                                        nameStart+r*state.FILENAME_LENGTH-1);\n                z = find(nb==0,1);\n                if ~isempty(z); nb=nb(1:z-1); end\n                names{r} = char(nb');\n            end\n            fileName = majorityVote(names);\n\n            % Extract file size (mode)\n            szStart = nameStart + state.FILENAME_LENGTH*state.REPETITIONS;\n            sizes = zeros(state.REPETITIONS,1,'uint64');\n            for r = 1:state.REPETITIONS\n                raw = state.streamBuffer(szStart+(r-1)*8 : szStart+r*8-1);\n                sizes(r) = typecast(uint8(raw),'uint64');\n            end\n            fileSize = mode(sizes);\n\n            safeName  = regexprep(fileName, '[\\\\/:*?\"<>|]', '_');\n            tempPath  = fullfile(state.outputDirectory, [safeName '.part']);\n            finalPath = fullfile(state.outputDirectory, safeName);\n\n            fid = fopen(tempPath, 'wb');\n            if fid == -1\n                fprintf('[FileSink] ERROR: Cannot create %s\\n', tempPath); break;\n            end\n\n            fprintf('[FileSink] Started: %s (%.2f MB)\\n', fileName, fileSize/1e6);\n\n            state.currentFile = struct( ...\n                'active',       true, ...\n                'fid',          fid, ...\n                'name',         fileName, ...\n                'tempPath',     tempPath, ...\n                'finalPath',    finalPath, ...\n                'expectedSize', fileSize, ...\n                'writtenBytes', uint64(0), ...\n                'errorCount',   uint64(0) ...\n            );\n            state.lastProgressPct = -1;\n\n            dataStart = startPos + metaSize;\n            state.streamBuffer = state.streamBuffer(dataStart:end);\n\n        else\n            remaining = state.currentFile.expectedSize - state.currentFile.writtenBytes;\n\n            if remaining == 0\n                if numel(state.streamBuffer) < 4; break; end\n                if isequal(state.streamBuffer(1:4), state.END_FLAG(:)')\n                    state.streamBuffer = state.streamBuffer(5:end);\n                    fclose(state.currentFile.fid);\n                    movefile(state.currentFile.tempPath, state.currentFile.finalPath);\n                    appendReport(state.reportPath, state.currentFile);\n\n                    if state.currentFile.errorCount > 0\n                        errRate = 100 * double(state.currentFile.errorCount) / ...\n                                        double(state.currentFile.expectedSize);\n                        fprintf('[FileSink] Completed: %s — %d errors (%.4f%%)\\n', ...\n                            state.currentFile.name, state.currentFile.errorCount, errRate);\n                    else\n                        fprintf('[FileSink] Completed: %s — Clean\\n', state.currentFile.name);\n                    end\n\n                    state.filesReceived = state.filesReceived + 1;\n                    state.currentFile.active = false;\n                else\n                    fprintf('[FileSink] WARNING: END flag mismatch for %s\\n', state.currentFile.name);\n                    fclose(state.currentFile.fid);\n                    appendReport(state.reportPath, state.currentFile);\n                    state.currentFile.active = false;\n                    state.streamBuffer = state.streamBuffer(5:end);\n                end\n            else\n                toWrite = min(remaining, uint64(numel(state.streamBuffer)));\n                if toWrite == 0; break; end\n\n                fwrite(state.currentFile.fid, state.streamBuffer(1:toWrite), 'uint8');\n                state.currentFile.writtenBytes = state.currentFile.writtenBytes + toWrite;\n                state.streamBuffer = state.streamBuffer(toWrite+1:end);\n\n                pct = floor(100 * double(state.currentFile.writtenBytes) / ...\n                                  double(state.currentFile.expectedSize));\n                if mod(pct,10)==0 && pct ~= state.lastProgressPct\n                    fprintf('[FileSink]   %s - %d%% (%.2f / %.2f MB)\\n', ...\n                        state.currentFile.name, pct, ...\n                        double(state.currentFile.writtenBytes)/1e6, ...\n                        double(state.currentFile.expectedSize)/1e6);\n                    state.lastProgressPct = pct;\n                end\n            end\n        end\n    end\nend\n\n%% ─── Helpers ────────────────────────────────────────────────────────────────\nfunction pos = findPattern(data, pattern)\n    pos = [];\n    plen = numel(pattern);\n    if numel(data) < plen; return; end\n    for i = 1:numel(data)-plen+1\n        if isequal(data(i:i+plen-1), pattern(:)')\n            pos = i; return;\n        end\n    end\nend\n\nfunction result = majorityVote(strings)\n    [u,~,idx] = unique(strings);\n    counts = histc(idx, 1:numel(u));\n    [~,mi] = max(counts);\n    result = u{mi};\nend\n\nfunction appendReport(path, fi)\n    fid = fopen(path, 'a');\n    if fid == -1; return; end\n    fprintf(fid, '[%s]\\nFile: %s\\n  Size: %d bytes (%.2f MB)\\n  Errors: %d\\n', ...\n        datestr(now), fi.name, fi.expectedSize, fi.expectedSize/1e6, fi.errorCount);\n    if fi.errorCount > 0\n        fprintf(fid, '  Error Rate: %.4f%%\\n  Status: CORRUPTED\\n\\n', ...\n            100*double(fi.errorCount)/double(fi.expectedSize));\n    else\n        fprintf(fid, '  Status: CLEAN\\n\\n');\n    end\n    fclose(fid);\nend\n",
      "inputs": 1,
