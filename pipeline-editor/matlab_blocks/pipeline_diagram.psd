        "socketHost": "localhost",
        "socketPort": 9001,
        "sourceDirectory": "C:\\Users\\amrga\\Downloads\\final\\pipeline-editor\\Test_Files",
        "loopMode": false,
        "description": "File source block - sends all files once then exits"
