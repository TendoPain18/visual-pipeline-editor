    {
      "id": 1017,
      "name": "interleaver_middleman",
      "fileName": "interleaver_middleman.cpp",
      "code": "#include \"core/run_generic_block.h\"\n#include <cstring>\n\n// ============================================================\n// Interleaver Middleman  (test/bypass block for interleaver layer)\n//\n// Sits between interleaver and deinterleaver for isolated testing.\n// Will be removed once the interleaver layer is verified.\n//\n// Inputs:\n//   in[0]: Interleaved DATA from interleaver     (3030 bytes/pkt)  <- FIRST\n//   in[1]: rate_encoded_length from interleaver  (3 bytes/pkt)\n//   in[2]: Feedback from ppdu_decapsulate        (3 bytes/pkt)\n//             Byte 0: rate_value\n//             Byte 1: mac_len_lo\n//             Byte 2: mac_len_hi\n//\n// Outputs:\n//   out[0]: rate + DATA_INTERLEAVED -> deinterleaver (3025 bytes/pkt)  <- FIRST\n//             Byte 0: rate_value\n//             Bytes [1..]: interleaved DATA (remaining after SIGNAL)\n//   out[1]: SIGNAL_INTERLEAVED -> deinterleaver  (6 bytes/pkt)\n//\n// Protocol per batch:\n//   1. Read interleaved DATA batch   (in[0])  -- FIRST (rate measurement)\n//   2. Read rate_encoded_length      (in[1])  -- discard (rate comes from feedback)\n//   3. Split: first 6 bytes = SIGNAL_INTERLEAVED, rest = DATA_INTERLEAVED\n//   4. Send SIGNAL_INTERLEAVED batch (out[1]) -- SIGNAL\n//   5. Wait for feedback             (in[2])  -- gate; extract rate_value\n//   6. Send rate + DATA_INTERLEAVED  (out[0]) -- DATA FIRST\n//\n// Mirrors the same deadlock-free pattern used by ppdu_middleman,\n// scrambler_middleman, and channel_encode_middleman.\n// ============================================================\n\nstatic const int DEBUG_PKT_LIMIT = 3;\n\nstruct InterleaverMiddlemanData {\n    int frameCount;\n};\n\nInterleaverMiddlemanData init_interleaver_middleman(const BlockConfig& config) {\n    InterleaverMiddlemanData data;\n    data.frameCount = 0;\n\n    printf(\"[InterleaverMiddleman] Staged I/O mode\\n\");\n    printf(\"[InterleaverMiddleman] Sequence per batch:\\n\");\n    printf(\"[InterleaverMiddleman]   1. Read interleaved DATA (in[0], 3030B) -- FIRST\\n\");\n    printf(\"[InterleaverMiddleman]   2. Read rate_enc_len     (in[1], 3B)    -- discarded\\n\");\n    printf(\"[InterleaverMiddleman]   3. Send SIGNAL_INT       (out[1], 6B)   -- SIGNAL\\n\");\n    printf(\"[InterleaverMiddleman]   4. Wait for feedback     (in[2], 3B)    -- gate\\n\");\n    printf(\"[InterleaverMiddleman]   5. Send rate+DATA_INT    (out[0], 3025B)-- DATA first\\n\");\n    printf(\"[InterleaverMiddleman] Debug: first %d packets of first batch logged\\n\",\n           DEBUG_PKT_LIMIT);\n    printf(\"[InterleaverMiddleman] Ready\\n\");\n\n    return data;\n}\n\nvoid process_interleaver_middleman(\n    const char** pipeIn,\n    const char** pipeOut,\n    InterleaverMiddlemanData& customData,\n    const BlockConfig& config\n) {\n    // in[0] = Interleaved DATA (3030) -- FIRST\n    // in[1] = rate_encoded_length (3)\n    // in[2] = Feedback from ppdu_decap (3)\n    // out[0] = rate + DATA_INTERLEAVED (3025) -- FIRST\n    // out[1] = SIGNAL_INTERLEAVED (6)\n    PipeIO inData    (pipeIn[0],  config.inputPacketSizes[0],  config.inputBatchSizes[0]);\n    PipeIO inRate    (pipeIn[1],  config.inputPacketSizes[1],  config.inputBatchSizes[1]);\n    PipeIO inFeedback(pipeIn[2],  config.inputPacketSizes[2],  config.inputBatchSizes[2]);\n    PipeIO outData   (pipeOut[0], config.outputPacketSizes[0], config.outputBatchSizes[0]);\n    PipeIO outSignal (pipeOut[1], config.outputPacketSizes[1], config.outputBatchSizes[1]);\n\n    int8_t* dataBuf     = new int8_t[inData.getBufferSize()];\n    int8_t* rateBuf     = new int8_t[inRate.getBufferSize()];\n    int8_t* feedbackBuf = new int8_t[inFeedback.getBufferSize()];\n    int8_t* signalBuf   = new int8_t[outSignal.getBufferSize()];\n    int8_t* dataOutBuf  = new int8_t[outData.getBufferSize()];\n\n    const int inDataPkt   = config.inputPacketSizes[0];   // 3030\n    const int inFbPkt     = config.inputPacketSizes[2];   // 3\n    const int outDataPkt  = config.outputPacketSizes[0];  // 3025\n    const int outSigPkt   = config.outputPacketSizes[1];  // 6\n\n    const bool isFirstBatch = (customData.frameCount == 0);\n\n    // ===== STEP 1: Read interleaved DATA batch first (rate measurement) =====\n    int actualCount = inData.read(dataBuf);\n\n    // ===== STEP 2: Read rate_encoded_length batch (discard) =====\n    inRate.read(rateBuf);\n\n    memset(signalBuf,  0, outSignal.getBufferSize());\n    memset(dataOutBuf, 0, outData.getBufferSize());\n\n    // ===== STEP 3: Split SIGNAL_INTERLEAVED (6B) from DATA_INTERLEAVED =====\n    for (int i = 0; i < actualCount; i++) {\n        const bool dbg = isFirstBatch && (i < DEBUG_PKT_LIMIT);\n\n        const int inOff   = i * inDataPkt;\n        const int sigOff  = i * outSigPkt;\n        const int dataOff = i * outDataPkt;\n\n        // First 6 bytes (48 bits) = SIGNAL_INTERLEAVED\n        memcpy(signalBuf + sigOff, dataBuf + inOff, 6);\n\n        // Remaining bytes = DATA_INTERLEAVED -> bytes [1..] (byte 0 reserved for rate)\n        int copyLen = inDataPkt - 6;\n        if (copyLen > outDataPkt - 1) copyLen = outDataPkt - 1;\n        memcpy(dataOutBuf + dataOff + 1, dataBuf + inOff + 6, copyLen);\n\n        if (dbg) {\n            uint8_t s0 = (uint8_t)((int32_t)signalBuf[sigOff + 0] + 128);\n            uint8_t s1 = (uint8_t)((int32_t)signalBuf[sigOff + 1] + 128);\n            uint8_t s2 = (uint8_t)((int32_t)signalBuf[sigOff + 2] + 128);\n            uint8_t s3 = (uint8_t)((int32_t)signalBuf[sigOff + 3] + 128);\n            uint8_t s4 = (uint8_t)((int32_t)signalBuf[sigOff + 4] + 128);\n            uint8_t s5 = (uint8_t)((int32_t)signalBuf[sigOff + 5] + 128);\n            printf(\"[InterleaverMiddleman] DBG pkt[%d] SIGNAL_INT split: \"\n                   \"%02X %02X %02X %02X %02X %02X\\n\",\n                   i, s0, s1, s2, s3, s4, s5);\n        }\n    }\n\n    // ===== STEP 4: Send SIGNAL_INTERLEAVED batch (out[1]) =====\n    outSignal.write(signalBuf, actualCount);\n\n    // ===== STEP 5: Wait for feedback from ppdu_decapsulate (gate) =====\n    inFeedback.read(feedbackBuf);\n\n    // ===== STEP 6: Prepend rate_value from feedback to each DATA packet, then send =====\n    for (int i = 0; i < actualCount; i++) {\n        const bool dbg = isFirstBatch && (i < DEBUG_PKT_LIMIT);\n\n        const int fbOff   = i * inFbPkt;\n        const int dataOff = i * outDataPkt;\n\n        uint8_t rateVal = (uint8_t)((int32_t)feedbackBuf[fbOff + 0] + 128);\n        dataOutBuf[dataOff + 0] = (int8_t)((int32_t)rateVal - 128);\n\n        if (dbg) {\n            printf(\"[InterleaverMiddleman] DBG pkt[%d] feedback rateVal=%u -> \"\n                   \"prepended to DATA pkt\\n\", i, (unsigned)rateVal);\n        }\n    }\n\n    outData.write(dataOutBuf, actualCount);\n\n    customData.frameCount += actualCount;\n\n    delete[] dataBuf;\n    delete[] rateBuf;\n    delete[] feedbackBuf;\n    delete[] signalBuf;\n    delete[] dataOutBuf;\n}\n\nint main(int argc, char* argv[]) {\n    if (argc < 6) {\n        fprintf(stderr,\n            \"Usage: interleaver_middleman <pipeInData> <pipeInRate> <pipeInFeedback>\"\n            \" <pipeOutSignal> <pipeOutData>\\n\");\n        return 1;\n    }\n\n    const char* pipeIns[]  = {argv[1], argv[2], argv[3]};\n    const char* pipeOuts[] = {argv[4], argv[5]};\n\n    BlockConfig config = {\n        \"InterleaverMiddleman\",\n        3,                         // inputs\n        2,                         // outputs\n        {3030, 3, 3},              // inputPacketSizes  [INT_DATA, rate_enc_len, feedback]\n        {6000, 6000, 6000},        // inputBatchSizes\n        {3025, 6},                 // outputPacketSizes [rate+DATA_INT, SIGNAL_INT]\n        {6000, 6000},              // outputBatchSizes\n        false,                     // ltr (middleman)\n        true,                      // startWithAll\n        \"Interleaver middleman: SIGNAL_INT first, gate on ppdu_decap feedback, rate+DATA_INT second\"\n    };\n\n    run_manual_block(pipeIns, pipeOuts, config,\n                     process_interleaver_middleman,\n                     init_interleaver_middleman);\n    return 0;\n}",
