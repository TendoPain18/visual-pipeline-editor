    {
      "id": 1009,
      "name": "descrambler",
      "fileName": "descrambler.cpp",
      "code": "#include \"core/run_generic_block.h\"\n#include <cstring>\n\n// ============================================================\n// IEEE 802.11a Descrambler\n//\n// Inputs:\n//   in[0]: Scrambled DATA  (1515 bytes/pkt, max)  <- [0] for rate counter only\n//   in[1]: SIGNAL          (3 bytes/pkt)\n//\n// Outputs:\n//   out[0]: Descrambled DATA  (1515 bytes/pkt, max)  <- [0] for rate counter only\n//   out[1]: SIGNAL passthrough (3 bytes/pkt)  -> ppdu_decapsulate\n//\n// Protocol (deadlock-free):\n//   1. Read SIGNAL (in[1])    -- SIGNAL physically arrives FIRST\n//   2. Send SIGNAL (out[1])   -- ppdu_decap reads it, sends feedback to middleman,\n//                                middleman then sends DATA to us\n//                                (we do NOT wait for that feedback here)\n//   3. Read DATA (in[0])      -- DATA arrives after middleman got feedback\n//   4. Descramble DATA: extract seed from byte[3] bits[6:0], XOR with LUT[seed]\n//                       SIGNAL bytes [0..2] copied unchanged\n//   5. Send descrambled DATA (out[0])\n//\n// lip (length_in_pipe) is derived from the SIGNAL field:\n//   rate + mac_length -> frame_bytes = 3+2+mac_length+tail_pad_bytes\n//   Only bytes [0..frame_bytes-1] are descrambled; rest zeroed.\n//\n// Scrambler polynomial: S(x) = x^7 + x^4 + 1\n// ============================================================\n\nstatic int rateValToNDBPS(uint8_t rv) {\n    switch (rv) {\n        case 13: return  24;  //  6 Mbps\n        case 15: return  36;  //  9 Mbps\n        case  5: return  48;  // 12 Mbps\n        case  7: return  72;  // 18 Mbps\n        case  9: return  96;  // 24 Mbps\n        case 11: return 144;  // 36 Mbps\n        case  1: return 192;  // 48 Mbps\n        case  3: return 216;  // 54 Mbps\n        default: return  48;\n    }\n}\n\nstatic int frameBytes(uint8_t rateVal, uint16_t macLength) {\n    int ndbps     = rateValToNDBPS(rateVal);\n    int dbits     = 16 + (int)macLength * 8 + 6;\n    int nsym      = (dbits + ndbps - 1) / ndbps;\n    int totbits   = nsym * ndbps;\n    int padbits   = totbits - dbits;\n    int tpbytes   = (6 + padbits + 7) / 8;\n    return 3 + 2 + (int)macLength + tpbytes;\n}\n\nstruct DescramblerData {\n    int     frameCount;\n    uint8_t lut[128][1515];\n};\n\nDescramblerData init_descrambler(const BlockConfig& config) {\n    DescramblerData data;\n    data.frameCount = 0;\n\n    printf(\"[Descrambler] Polynomial: S(x) = x^7 + x^4 + 1\\n\");\n    printf(\"[Descrambler] Building LUT for seeds 1..127 (1515 bytes each)...\\n\");\n\n    for (int seed = 1; seed <= 127; seed++) {\n        uint8_t st[7];\n        for (int b = 0; b < 7; b++) st[b] = (seed >> (6 - b)) & 1;\n        for (int bi = 0; bi < 1515; bi++) {\n            uint8_t sb = 0;\n            for (int bit = 0; bit < 8; bit++) {\n                sb |= (st[6] << bit);\n                uint8_t nb = st[6] ^ st[3];\n                for (int s = 6; s > 0; s--) st[s] = st[s - 1];\n                st[0] = nb;\n            }\n            data.lut[seed][bi] = sb;\n        }\n    }\n\n    printf(\"[Descrambler] LUT built (128 x 1515 bytes)\\n\");\n    printf(\"[Descrambler] Protocol (deadlock-free):\\n\");\n    printf(\"[Descrambler]   1. Read SIGNAL (in[1])  -- arrives first\\n\");\n    printf(\"[Descrambler]   2. Send SIGNAL (out[1]) -- ppdu_decap unblocks, sends feedback\\n\");\n    printf(\"[Descrambler]   3. Read DATA   (in[0])  -- arrives after middleman gets feedback\\n\");\n    printf(\"[Descrambler]   4. Descramble, send DATA (out[0])\\n\");\n    printf(\"[Descrambler] Ready\\n\");\n\n    return data;\n}\n\nvoid process_descrambler(\n    const char** pipeIn,\n    const char** pipeOut,\n    DescramblerData& customData,\n    const BlockConfig& config\n) {\n    PipeIO inData   (pipeIn[0],  config.inputPacketSizes[0],  config.inputBatchSizes[0]);  // 1515\n    PipeIO inSignal (pipeIn[1],  config.inputPacketSizes[1],  config.inputBatchSizes[1]);  // 3\n    PipeIO outData  (pipeOut[0], config.outputPacketSizes[0], config.outputBatchSizes[0]); // 1515\n    PipeIO outSignal(pipeOut[1], config.outputPacketSizes[1], config.outputBatchSizes[1]); // 3\n\n    int8_t* signalBuf  = new int8_t[inSignal.getBufferSize()];\n    int8_t* dataBuf    = new int8_t[inData.getBufferSize()];\n    int8_t* sigOutBuf  = new int8_t[outSignal.getBufferSize()];\n    int8_t* dataOutBuf = new int8_t[outData.getBufferSize()];\n\n    const int inSigPkt  = config.inputPacketSizes[1];   // 3\n    const int inDataPkt = config.inputPacketSizes[0];   // 1515\n    const int outDataPkt= config.outputPacketSizes[0];  // 1515\n\n    // ===== STEP 1: Read SIGNAL -- it physically arrives first =====\n    int actualCount = inSignal.read(signalBuf);\n\n    // ===== STEP 2: Pass SIGNAL through immediately =====\n    // ppdu_decap will parse it, send feedback to upstream middleman,\n    // which then sends DATA to us. We don't wait for that feedback here.\n    memcpy(sigOutBuf, signalBuf, outSignal.getBufferSize());\n    outSignal.write(sigOutBuf, actualCount);\n\n    // ===== STEP 3: Read DATA -- arrives now that middleman has gotten feedback =====\n    inData.read(dataBuf);\n\n    // ===== STEP 4: Descramble each packet =====\n    memset(dataOutBuf, 0, outData.getBufferSize());\n\n    for (int i = 0; i < actualCount; i++) {\n        const int sigOff  = i * inSigPkt;\n        const int dataOff = i * inDataPkt;\n        const int outOff  = i * outDataPkt;\n\n        // Parse SIGNAL to get lip\n        uint8_t b0 = (uint8_t)((int32_t)signalBuf[sigOff + 0] + 128);\n        uint8_t b1 = (uint8_t)((int32_t)signalBuf[sigOff + 1] + 128);\n        uint8_t b2 = (uint8_t)((int32_t)signalBuf[sigOff + 2] + 128);\n\n        uint8_t  rateVal   = b0 & 0x0F;\n        uint16_t macLength = (uint16_t)((b0 >> 5) & 0x07)\n                           | ((uint16_t)b1 << 3)\n                           | (((uint16_t)(b2 & 0x01)) << 11);\n\n        if (macLength == 0 || macLength > 4095) macLength = 1504;\n\n        int lip = frameBytes(rateVal, macLength);\n        if (lip > inDataPkt) lip = inDataPkt;\n\n        // Convert meaningful bytes to uint8\n        uint8_t pkt[1515];\n        for (int j = 0; j < lip; j++)\n            pkt[j] = (uint8_t)((int32_t)dataBuf[dataOff + j] + 128);\n\n        // Extract seed from SERVICE byte 0 bits[6:0]\n        uint8_t seed = pkt[3] & 0x7F;\n        if (seed == 0) seed = 1;\n\n        const uint8_t* seq = customData.lut[seed];\n\n        // SIGNAL bytes [0..2]: copy unchanged (not scrambled)\n        uint8_t out[1515];\n        memset(out, 0, sizeof(out));\n        out[0] = pkt[0];\n        out[1] = pkt[1];\n        out[2] = pkt[2];\n\n        // Descramble bytes [3..lip-1]\n        for (int j = 3; j < lip; j++)\n            out[j] = pkt[j] ^ seq[j];\n\n        // Convert to int8\n        for (int j = 0; j < lip; j++)\n            dataOutBuf[outOff + j] = (int8_t)((int32_t)out[j] - 128);\n    }\n\n    // ===== STEP 5: Send descrambled DATA =====\n    outData.write(dataOutBuf, actualCount);\n\n    customData.frameCount += actualCount;\n\n    delete[] signalBuf;\n    delete[] dataBuf;\n    delete[] sigOutBuf;\n    delete[] dataOutBuf;\n}\n\nint main(int argc, char* argv[]) {\n    if (argc < 5) {\n        fprintf(stderr,\n            \"Usage: descrambler <pipeInData> <pipeInSignal> <pipeOutData> <pipeOutSignal>\\n\");\n        return 1;\n    }\n    const char* pipeIns[]  = {argv[1], argv[2]};\n    const char* pipeOuts[] = {argv[3], argv[4]};\n\n    BlockConfig config = {\n        \"Descrambler\",\n        2,               // inputs\n        2,               // outputs\n        {1515, 3},       // inputPacketSizes  [DATA@[0] rate counter, SIGNAL@[1]]\n        {6000, 6000},  // inputBatchSizes\n        {1515, 3},       // outputPacketSizes [DATA@[0] rate counter, SIGNAL@[1]]\n        {6000, 6000},  // outputBatchSizes\n        true,            // ltr\n        true,            // startWithAll\n        \"Descrambler: SIGNAL read+sent first (no feedback wait), DATA read+descrambled second\"\n    };\n\n    run_manual_block(pipeIns, pipeOuts, config, process_descrambler, init_descrambler);\n    return 0;\n}\n",
      "language": "cpp",
