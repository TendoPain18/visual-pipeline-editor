    {
      "id": 1016,
      "name": "deinterleaver",
      "fileName": "deinterleaver.cpp",
      "code": "#include \"core/run_generic_block.h\"\n#include <cstring>\n#include <cstdint>\n\n// ============================================================\n// IEEE 802.11a Deinterleaver\n//\n// Inputs:\n//   in[0]: Interleaved DATA  (3025 bytes/pkt)  <- [0] for rate counter only\n//             Byte 0: rate_value\n//             Bytes [1..]: interleaved DATA bits\n//   in[1]: SIGNAL_INTERLEAVED (6 bytes/pkt)\n//\n// Outputs:\n//   out[0]: Deinterleaved DATA (3025 bytes/pkt) <- [0] for rate counter only\n//             Byte 0: rate_value (passthrough)\n//             Bytes [1..]: deinterleaved DATA bits\n//   out[1]: Deinterleaved SIGNAL (6 bytes/pkt)\n//\n// Protocol (deadlock-free) -- mirrors descrambler.cpp exactly:\n//   1. Read SIGNAL_INTERLEAVED (in[1])  -- arrives FIRST (middleman sends it first)\n//   2. Deinterleave SIGNAL (BPSK, NCBPS=48)\n//   3. Send deinterleaved SIGNAL (out[1]) -- ppdu_decap reads it, sends feedback\n//                                            to upstream middleman, which then\n//                                            sends DATA to us (we do NOT wait here)\n//   4. Read DATA (in[0])             -- arrives after middleman received feedback\n//   5. Extract rate from byte 0, deinterleave DATA bits with rate-dependent params\n//   6. Send deinterleaved DATA (out[0])\n//\n// Deinterleaver inverse permutation (reverses two-step interleaver):\n//   Given output index j from interleaver: j = s*floor(i/s) + mod(i+NCBPS-floor(16*i/NCBPS),s)\n//   and i = (NCBPS/16)*mod(k,16) + floor(k/16)\n//   Inverse: for each j, find k such that interleave(k) == j.\n//   Equivalently: build the forward map fwd[k]=j, then inv[j]=k.\n//\n// Rate -> (NBPSC, NCBPS):\n//   13 ->  6 Mbps: BPSK,   NBPSC=1, NCBPS=48\n//   15 ->  9 Mbps: BPSK,   NBPSC=1, NCBPS=48\n//    5 -> 12 Mbps: QPSK,   NBPSC=2, NCBPS=96\n//    7 -> 18 Mbps: QPSK,   NBPSC=2, NCBPS=96\n//    9 -> 24 Mbps: 16-QAM, NBPSC=4, NCBPS=192\n//   11 -> 36 Mbps: 16-QAM, NBPSC=4, NCBPS=192\n//    1 -> 48 Mbps: 64-QAM, NBPSC=6, NCBPS=288\n//    3 -> 54 Mbps: 64-QAM, NBPSC=6, NCBPS=288\n// ============================================================\n\nstruct RateModParams {\n    int NBPSC;\n    int NCBPS;\n};\n\nstatic RateModParams getModParams(uint8_t rateVal) {\n    switch (rateVal) {\n        case 13: return {1,  48};\n        case 15: return {1,  48};\n        case  5: return {2,  96};\n        case  7: return {2,  96};\n        case  9: return {4, 192};\n        case 11: return {4, 192};\n        case  1: return {6, 288};\n        case  3: return {6, 288};\n        default: return {2,  96};\n    }\n}\n\n// Deinterleave a block of NCBPS bits.\n// Builds the forward interleaver map then inverts it.\nstatic void deinterleave_block(const uint8_t* bits, uint8_t* out, int NCBPS, int NBPSC) {\n    int s = (NBPSC / 2 > 1) ? NBPSC / 2 : 1;\n\n    // Build forward map: fwd[k] = j (interleaver output position for input k)\n    int* fwd = new int[NCBPS];\n    for (int k = 0; k < NCBPS; k++) {\n        int i = (NCBPS / 16) * (k % 16) + k / 16;\n        int j = s * (i / s) + (i + NCBPS - (16 * i / NCBPS)) % s;\n        fwd[k] = j;\n    }\n\n    // Invert: inv[j] = k  => out[k] = bits[j]\n    for (int k = 0; k < NCBPS; k++) {\n        out[k] = bits[fwd[k]];\n    }\n\n    delete[] fwd;\n}\n\nstruct DeinterleaverData {\n    int frameCount;\n};\n\nDeinterleaverData init_deinterleaver(const BlockConfig& config) {\n    DeinterleaverData data;\n    data.frameCount = 0;\n\n    printf(\"[Deinterleaver] IEEE 802.11a two-step deinterleaver (inverse)\\n\");\n    printf(\"[Deinterleaver] Protocol (deadlock-free):\\n\");\n    printf(\"[Deinterleaver]   1. Read SIGNAL_INT (in[1])   -- arrives first\\n\");\n    printf(\"[Deinterleaver]   2. Deinterleave SIGNAL (BPSK, NCBPS=48)\\n\");\n    printf(\"[Deinterleaver]   3. Send SIGNAL (out[1])      -- ppdu_decap unblocks, sends feedback\\n\");\n    printf(\"[Deinterleaver]   4. Read DATA   (in[0])       -- arrives after middleman gets feedback\\n\");\n    printf(\"[Deinterleaver]   5. Deinterleave DATA (rate-dependent)\\n\");\n    printf(\"[Deinterleaver]   6. Send DATA   (out[0])\\n\");\n    printf(\"[Deinterleaver] Ready\\n\");\n\n    return data;\n}\n\nvoid process_deinterleaver(\n    const char** pipeIn,\n    const char** pipeOut,\n    DeinterleaverData& customData,\n    const BlockConfig& config\n) {\n    // in[0]  = DATA (3025, byte0=rate, bytes[1..]=interleaved data) -- rate counter only\n    // in[1]  = SIGNAL_INTERLEAVED (6)\n    // out[0] = Deinterleaved DATA (3025, byte0=rate passthrough) -- rate counter only\n    // out[1] = Deinterleaved SIGNAL (6)\n    PipeIO inData    (pipeIn[0],  config.inputPacketSizes[0],  config.inputBatchSizes[0]);\n    PipeIO inSignal  (pipeIn[1],  config.inputPacketSizes[1],  config.inputBatchSizes[1]);\n    PipeIO outData   (pipeOut[0], config.outputPacketSizes[0], config.outputBatchSizes[0]);\n    PipeIO outSignal (pipeOut[1], config.outputPacketSizes[1], config.outputBatchSizes[1]);\n\n    int8_t* signalBuf   = new int8_t[inSignal.getBufferSize()];\n    int8_t* dataBuf     = new int8_t[inData.getBufferSize()];\n    int8_t* sigOutBuf   = new int8_t[outSignal.getBufferSize()];\n    int8_t* dataOutBuf  = new int8_t[outData.getBufferSize()];\n\n    const int inSigPkt   = config.inputPacketSizes[1];   // 6\n    const int inDataPkt  = config.inputPacketSizes[0];   // 3025\n    const int outSigPkt  = config.outputPacketSizes[1];  // 6\n    const int outDataPkt = config.outputPacketSizes[0];  // 3025\n\n    // ===== STEP 1: Read SIGNAL_INTERLEAVED -- it physically arrives first =====\n    int actualCount = inSignal.read(signalBuf);\n\n    memset(sigOutBuf,  0, outSignal.getBufferSize());\n    memset(dataOutBuf, 0, outData.getBufferSize());\n\n    // ===== STEP 2 + 3: Deinterleave SIGNAL and send immediately =====\n    // SIGNAL is always BPSK: NCBPS=48, NBPSC=1\n    for (int i = 0; i < actualCount; i++) {\n        const int sigOff    = i * inSigPkt;\n        const int sigOutOff = i * outSigPkt;\n\n        // Convert 6 bytes to uint8\n        uint8_t sigBytes[6];\n        for (int j = 0; j < 6; j++) {\n            sigBytes[j] = (uint8_t)((int32_t)signalBuf[sigOff + j] + 128);\n        }\n\n        // Expand to 48 bits (right-MSB bit order to match interleaver)\n        uint8_t inBits[48];\n        for (int byte = 0; byte < 6; byte++) {\n            for (int bit = 0; bit < 8; bit++) {\n                inBits[byte * 8 + bit] = (sigBytes[byte] >> bit) & 1;\n            }\n        }\n\n        // Deinterleave (BPSK: NCBPS=48, NBPSC=1)\n        uint8_t outBits[48];\n        deinterleave_block(inBits, outBits, 48, 1);\n\n        // Pack back to bytes\n        uint8_t outBytes[6] = {};\n        for (int byte = 0; byte < 6; byte++) {\n            for (int bit = 0; bit < 8; bit++) {\n                outBytes[byte] |= (outBits[byte * 8 + bit] & 1) << bit;\n            }\n        }\n\n        // Convert to int8\n        for (int j = 0; j < 6; j++) {\n            sigOutBuf[sigOutOff + j] = (int8_t)((int32_t)outBytes[j] - 128);\n        }\n    }\n\n    // Send SIGNAL immediately -- ppdu_decap will parse it, send feedback to\n    // the upstream middleman, which then sends DATA to us.\n    outSignal.write(sigOutBuf, actualCount);\n\n    // ===== STEP 4: Read DATA -- arrives now that middleman got feedback =====\n    inData.read(dataBuf);\n\n    // ===== STEP 5: Deinterleave DATA for each packet =====\n    for (int i = 0; i < actualCount; i++) {\n        const int dataOff    = i * inDataPkt;\n        const int dataOutOff = i * outDataPkt;\n\n        // Byte 0 = rate_value (passthrough)\n        uint8_t rateVal = (uint8_t)((int32_t)dataBuf[dataOff + 0] + 128);\n        dataOutBuf[dataOutOff + 0] = dataBuf[dataOff + 0];  // pass rate through as-is\n\n        // Remaining bytes = interleaved DATA\n        int numDataBytes = inDataPkt - 1;  // 3024\n        uint8_t dataBytes[3024];\n        for (int j = 0; j < numDataBytes; j++) {\n            dataBytes[j] = (uint8_t)((int32_t)dataBuf[dataOff + 1 + j] + 128);\n        }\n\n        // Get rate-dependent interleaver params\n        RateModParams mp = getModParams(rateVal);\n        int NCBPS = mp.NCBPS;\n        int NBPSC = mp.NBPSC;\n\n        // Expand to bits\n        int numBits = numDataBytes * 8;\n        uint8_t* inBits  = new uint8_t[numBits]();\n        uint8_t* outBits = new uint8_t[numBits]();\n\n        for (int byte = 0; byte < numDataBytes; byte++) {\n            for (int bit = 0; bit < 8; bit++) {\n                inBits[byte * 8 + bit] = (dataBytes[byte] >> bit) & 1;\n            }\n        }\n\n        // Deinterleave symbol by symbol\n        int numSymbols = numBits / NCBPS;\n        uint8_t* symIn  = new uint8_t[NCBPS];\n        uint8_t* symOut = new uint8_t[NCBPS];\n\n        for (int sym = 0; sym < numSymbols; sym++) {\n            int start = sym * NCBPS;\n            memcpy(symIn, inBits + start, NCBPS);\n            deinterleave_block(symIn, symOut, NCBPS, NBPSC);\n            memcpy(outBits + start, symOut, NCBPS);\n        }\n\n        // Remaining bits (partial symbol): copy unchanged\n        int processed = numSymbols * NCBPS;\n        if (processed < numBits) {\n            memcpy(outBits + processed, inBits + processed, numBits - processed);\n        }\n\n        // Pack bits back to bytes\n        uint8_t outBytes[3024] = {};\n        for (int byte = 0; byte < numDataBytes; byte++) {\n            for (int bit = 0; bit < 8; bit++) {\n                outBytes[byte] |= (outBits[byte * 8 + bit] & 1) << bit;\n            }\n        }\n\n        // Convert to int8 and place after rate byte\n        for (int j = 0; j < numDataBytes; j++) {\n            dataOutBuf[dataOutOff + 1 + j] = (int8_t)((int32_t)outBytes[j] - 128);\n        }\n\n        delete[] inBits;\n        delete[] outBits;\n        delete[] symIn;\n        delete[] symOut;\n    }\n\n    // ===== STEP 6: Send deinterleaved DATA =====\n    outData.write(dataOutBuf, actualCount);\n\n    customData.frameCount += actualCount;\n\n    delete[] signalBuf;\n    delete[] dataBuf;\n    delete[] sigOutBuf;\n    delete[] dataOutBuf;\n}\n\nint main(int argc, char* argv[]) {\n    if (argc < 5) {\n        fprintf(stderr,\n            \"Usage: deinterleaver <pipeInData> <pipeInSignal> <pipeOutData> <pipeOutSignal>\\n\");\n        return 1;\n    }\n\n    const char* pipeIns[]  = {argv[1], argv[2]};\n    const char* pipeOuts[] = {argv[3], argv[4]};\n\n    BlockConfig config = {\n        \"Deinterleaver\",\n        2,                 // inputs\n        2,                 // outputs\n        {3025, 6},         // inputPacketSizes  [rate+DATA@[0] rate counter, SIGNAL_INT@[1]]\n        {6000, 6000},      // inputBatchSizes\n        {3025, 6},         // outputPacketSizes [rate+DATA@[0] rate counter, SIGNAL@[1]]\n        {6000, 6000},      // outputBatchSizes\n        true,              // ltr\n        true,              // startWithAll\n        \"Deinterleaver: SIGNAL read+deinterleaved+sent first (no feedback wait), DATA deinterleaved second\"\n    };\n\n    run_manual_block(pipeIns, pipeOuts, config, process_deinterleaver, init_deinterleaver);\n    return 0;\n}\n",
      "language": "cpp",
