        ],
        "LTR": true,
        "startWithAll": true,
        "description": "IEEE 802.11a interleaver with length extraction"
      },
      "color": "#f59e0b",
      "portPositions": {
        "inputs": [
          {
            "x": 0,
            "y": 20,
            "type": "input",
            "index": 0
          },
          {
            "x": 0,
